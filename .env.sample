# Azure AI Foundry project endpoint
PROJECT_ENDPOINT=https://s2-oz-ai-projects.services.ai.azure.com/api/projects/s2-oz-ai-proj

# Model deployment name
MODEL_DEPLOYMENT=gpt-4o

# Agent name in Foundry
AGENT_NAME=foundry-skills

# MCP Server URL (APIM endpoint)
MCP_SERVER_URL=https://apim-sf-mcp-obo.azure-api.net/skills-mcp/mcp

# Azure Blob Storage (for MCP server + skill upload)
STORAGE_ACCOUNT=stfoundryskills
SKILLS_CONTAINER=skills

# MCP Server (local development)
MCP_HOST=0.0.0.0
MCP_PORT=8000
