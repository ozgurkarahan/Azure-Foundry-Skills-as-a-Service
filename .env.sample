# Azure AI Foundry project endpoint
PROJECT_ENDPOINT=https://s2-oz-ai-projects.services.ai.azure.com/api/projects/s2-oz-ai-proj

# Model deployment name (must exist in the AI Services account)
MODEL_DEPLOYMENT=gpt-4o

# Agent name in Foundry
AGENT_NAME=foundry-skills

# Azure Blob Storage (for skill file upload)
STORAGE_ACCOUNT=
SKILLS_CONTAINER=skills
